generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  SUPER_ADMIN
  USER
}

enum GymRole {
  OWNER
  MANAGER
  STAFF
  MEMBER
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}



enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JoinStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum GymVerificationStatus {
  NOT_SUBMITTED
  SUBMITTED
  PENDING_VISIT
  VISIT_ASSIGNED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  REVERIFICATION_REQUIRED
}

model User {
  id                    String        @id
  email                 String        @unique
  name                  String
  platformRole          PlatformRole  @default(USER)
  memberships           GymMember[]
  attendanceLog         Attendance[]
  stories               Story[]
  interactionRequests   InteractionRequest[]
  joinRequests          JoinRequest[]
  assignedVerifications GymVerification[] @relation("Verifier")
  auditLogsCreated      VerificationAuditLog[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Gym {
  id                       String        @id @default(uuid())
  slug                     String        @unique
  name                     String
  isActive                 Boolean       @default(false)
  ownerPhone               String?
  ownerEmail               String?
  ownerWhatsApp            String?
  address                  String?
  qrSecret                 String?       @default(dbgenerated("gen_random_uuid()"))
  members                  GymMember[]
  plans                    MembershipPlan[]
  announcements            Announcement[]
  stories                  Story[]
  attendance               Attendance[]
  trainerVerifications     TrainerVerificationRequest[]
  verifiedTrainers         Trainer[]
  joinRequests             JoinRequest[]
  verificationStatus       GymVerificationStatus @default(APPROVED)
  verification             GymVerification?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
}

model GymMember {
  id             String        @id @default(uuid())
  userId         String
  gymId          String
  role           GymRole       @default(MEMBER)
  status         MemberStatus  @default(ACTIVE)
  planId         String? 
  planExpiresAt  DateTime?
  user           User          @relation(fields: [userId], references: [id])
  gym            Gym           @relation(fields: [gymId], references: [id])
  plan           MembershipPlan? @relation(fields: [planId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([userId, gymId])
}

model MembershipPlan {
  id             String        @id @default(uuid())
  gymId          String
  name           String        
  durationDays   Int
  price          Float
  gym            Gym           @relation(fields: [gymId], references: [id])
  members        GymMember[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Announcement {
  id             String        @id @default(uuid())
  gymId          String
  title          String
  content        String
  gym            Gym           @relation(fields: [gymId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Story {
  id             String        @id @default(uuid())
  gymId          String
  userId         String
  imageUrl       String
  caption        String?
  createdAt      DateTime      @default(now())
  expiresAt      DateTime      
  gym            Gym           @relation(fields: [gymId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Attendance {
  id             String        @id @default(uuid())
  gymId          String
  userId         String
  memberName     String        @default("Unknown")
  planStatus     String        @default("Unknown")
  isSuccess      Boolean       @default(false)
  denialReason   String?
  scannedById    String?       
  entryTime      DateTime      @default(now())
  gym            Gym           @relation(fields: [gymId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  gymId     String?
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Trainer {
  id                    String        @id @default(uuid())
  userId                String        @unique
  name                  String
  email                 String
  phone                 String?
  specialization        String?
  bio                   String?
  gymName               String
  isVerified            Boolean       @default(false)
  verifiedByGymId       String?
  verifiedByGym         Gym?          @relation(fields: [verifiedByGymId], references: [id])
  verificationRequests  TrainerVerificationRequest[]
  interactionRequests   InteractionRequest[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model TrainerVerificationRequest {
  id             String              @id @default(uuid())
  trainerId      String
  gymId          String
  status         VerificationStatus  @default(PENDING)
  trainer        Trainer             @relation(fields: [trainerId], references: [id])
  gym            Gym                 @relation(fields: [gymId], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([trainerId, gymId])
}

model InteractionRequest {
  id             String              @id @default(uuid())
  userId         String
  trainerId      String
  status         VerificationStatus  @default(PENDING)
  user           User                @relation(fields: [userId], references: [id])
  trainer        Trainer             @relation(fields: [trainerId], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([userId, trainerId])
}

model JoinRequest {
  id             String      @id @default(uuid())
  userId         String
  gymId          String
  status         JoinStatus  @default(PENDING)
  user           User        @relation(fields: [userId], references: [id])
  gym            Gym         @relation(fields: [gymId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([userId, gymId])
}

model GymVerification {
  id               String   @id @default(uuid())
  gymId            String   @unique
  gym              Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  ownerName        String
  phone            String
  email            String
  address          String
  latitude         Float?
  longitude        Float?
  
  photos           Json     @default("[]")
  documents        Json     @default("[]")
  
  status           GymVerificationStatus @default(NOT_SUBMITTED)
  
  rejectionReason  String?
  suspensionReason String?
  
  assignedToId     String?
  assignedTo       User?    @relation("Verifier", fields: [assignedToId], references: [id])
  
  visitDate        DateTime?
  visitEvidence    Json     @default("[]")
  notes            String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  auditLogs        VerificationAuditLog[]
}

model VerificationAuditLog {
  id              String   @id @default(uuid())
  verificationId  String
  verification    GymVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  
  changedById     String?
  changedBy       User?    @relation(fields: [changedById], references: [id])
  
  oldStatus       GymVerificationStatus?
  newStatus       GymVerificationStatus
  reason          String?
  
  createdAt       DateTime @default(now())
}
