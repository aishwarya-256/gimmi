generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  SUPER_ADMIN
  USER
}

enum GymRole {
  OWNER
  MANAGER
  STAFF
  MEMBER
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum ScanStatus {
  SUCCESS
  DENIED_EXPIRED
  DENIED_COOLDOWN
  DENIED_INVALID
}

model User {
  id             String        @id
  email          String        @unique
  name           String
  platformRole   PlatformRole  @default(USER)
  memberships    GymMember[]
  attendanceLog  Attendance[]
  stories        Story[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Gym {
  id             String        @id @default(uuid())
  slug           String        @unique
  name           String
  isActive       Boolean       @default(false)
  members        GymMember[]
  plans          MembershipPlan[]
  announcements  Announcement[]
  stories        Story[]
  attendance     Attendance[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model GymMember {
  id             String        @id @default(uuid())
  userId         String
  gymId          String
  role           GymRole       @default(MEMBER)
  status         MemberStatus  @default(ACTIVE)
  planId         String? 
  user           User          @relation(fields: [userId], references: [id])
  gym            Gym           @relation(fields: [gymId], references: [id])
  plan           MembershipPlan? @relation(fields: [planId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([userId, gymId])
}

model MembershipPlan {
  id             String        @id @default(uuid())
  gymId          String
  name           String        
  durationDays   Int
  price          Float
  gym            Gym           @relation(fields: [gymId], references: [id])
  members        GymMember[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Announcement {
  id             String        @id @default(uuid())
  gymId          String
  title          String
  content        String
  gym            Gym           @relation(fields: [gymId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Story {
  id             String        @id @default(uuid())
  gymId          String
  userId         String
  imageUrl       String
  caption        String?
  createdAt      DateTime      @default(now())
  expiresAt      DateTime      
  gym            Gym           @relation(fields: [gymId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Attendance {
  id             String        @id @default(uuid())
  gymId          String
  userId         String
  scannedById    String?       
  entryTime      DateTime      @default(now())
  status         ScanStatus    
  gym            Gym           @relation(fields: [gymId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}
